# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend) - required for booking/career notifications
RESEND_API_KEY=your-resend-api-key
# Optional: override default from address.
# Default in development: OpusFesta <onboarding@resend.dev>
# Default in production: OpusFesta <noreply@thefestaevents.com>
# RESEND_FROM_EMAIL=
# Optional: platform admin email for inquiry notifications (default: admin@opusfesta.com)
# PLATFORM_ADMIN_EMAIL=
# Optional: studio "New Booking" notification recipient (default: ibadatt.aulakh@opusfesta.com)
# STUDIO_NOTIFICATION_EMAIL=ibadatt.aulakh@opusfesta.com

# File Upload (Cloudinary)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Stripe (Phase 4)
STRIPE_SECRET_KEY=your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
