# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email Configuration (Resend or SendGrid)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=OpusFesta <admin@opusfesta.com>

# Comma-separated list of admin emails that receive vendor application
# notifications. Falls back to active rows in admin_whitelist when unset.
VENDOR_NOTIFY_ADMIN_EMAIL=admin@opusfesta.com

# Public URL of the admin app — used to build deep links inside admin
# notification emails (e.g. /operations/vendors/[id]).
NEXT_PUBLIC_ADMIN_URL=https://admin.opusfesta.com

# Public URL of the vendors portal — used in vendor-facing emails.
NEXT_PUBLIC_VENDORS_PORTAL_URL=https://vendors.opusfesta.com

# File Upload (Cloudinary)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Stripe (Phase 4)
STRIPE_SECRET_KEY=your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
