{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "studio",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "dev", "--port", "3000"],
      "port": 3000,
      "cwd": "apps/studio"
    },
    {
      "name": "mobile",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "8082"],
      "port": 8082,
      "cwd": "apps/mobile"
    },
    {
      "name": "website",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "dev", "--port", "3006"],
      "port": 3006,
      "cwd": "apps/opus_website"
    },
    {
      "name": "opus_admin",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "dev"],
      "port": 3010,
      "autoPort": true,
      "cwd": "apps/opus_admin"
    },
    {
      "name": "vendors_portal",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "dev"],
      "port": 3003,
