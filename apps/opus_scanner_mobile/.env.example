# ─── opus_scanner API base ───────────────────────────────────────────────────
# Wherever apps/opus_scanner (the Next.js backend) is deployed. This mobile
# app calls its /api/access/resolve, /api/access/validate, /api/checkin
# routes over HTTPS — it never talks to Supabase tables directly.
EXPO_PUBLIC_SCANNER_API_BASE_URL="https://scanner.opuspass.example.com"

# ─── Supabase (Realtime broadcast only) ──────────────────────────────────────
# Anon key, used ONLY for subscribing to the "checkin:<eventId>" live
# broadcast channel — never for table reads/writes. Safe to expose.
EXPO_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"
