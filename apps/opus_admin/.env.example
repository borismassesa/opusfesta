# OpusFesta Supabase project (shared with opus_website)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only — keep out of NEXT_PUBLIC_*. Used for admin writes that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Clerk (shared with opus_website)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Admin app URL — used for self-referential links and revalidation callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3010

# Public site URL — used to revalidate opus_website pages on publish
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3007
WEBSITE_REVALIDATE_SECRET=

# Vendors portal URL — used to deep-link vendor lifecycle notification
# emails (approval / corrections / suspension) to the right portal page,
# AND to revalidate the vendors portal's ISR cache when admins publish
# changes from /cms/vendors-portal/*.
NEXT_PUBLIC_VENDORS_PORTAL_URL=http://localhost:3003
# Must match VENDORS_PORTAL_REVALIDATE_SECRET in the vendors_portal app.
# Without this, "Publish" in vendors-portal CMS sections will only update the
# database — public pages will keep serving stale ISR content until redeploy.
VENDORS_PORTAL_REVALIDATE_SECRET=

# Resend transactional email — contributor invites, future admin emails.
# Leave RESEND_API_KEY empty to fall back to a mailto: link in the admin UI.
# RESEND_FROM_EMAIL must be on a domain verified at https://resend.com/domains.
# For local development before verification, use Resend's built-in testing
# sender — note it only delivers to the Resend account owner's email:
#   RESEND_FROM_EMAIL=OpusFesta <onboarding@resend.dev>
RESEND_API_KEY=
RESEND_FROM_EMAIL=OpusFesta <admin@opusfesta.com>

# Where editorial submission notifications are sent. Comma-separated for
# multiple recipients. Leave empty to skip the email (the submission still
# lands in the admin Submissions tab regardless).
EDITORIAL_NOTIFY_EMAIL=editorial@opusfesta.com
