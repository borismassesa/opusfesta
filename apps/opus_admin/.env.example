# OpusFesta Supabase project (shared with opus_website)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only — keep out of NEXT_PUBLIC_*. Used for admin writes that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Clerk (shared with opus_website)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Admin app URL — used for self-referential links and revalidation callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3010

# Public site URL — used to revalidate opus_website pages on publish
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3007
WEBSITE_REVALIDATE_SECRET=
