# ─── Supabase (server) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="MY_SUPABASE_SERVICE_ROLE_KEY"

# ─── Supabase (browser) ──────────────────────────────────────────────────────
# Anon key, used ONLY for the Realtime Broadcast "recent activity" feed
# (lib/realtimeClient.ts) — never for table reads/writes, which stay
# server-only and service-role. Safe to expose (it's the public anon key).
NEXT_PUBLIC_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"

# ─── Check-in token signing ───────────────────────────────────────────────────
# MUST be the exact same value as apps/opus_pass's CHECKIN_TOKEN_SECRET — this
# app verifies tokens that opus_pass signs.
CHECKIN_TOKEN_SECRET="MY_CHECKIN_TOKEN_SECRET"
