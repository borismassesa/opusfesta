# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ─── Supabase (server) ───────────────────────────────────────────────────────
# Required by the payments order ledger (invitation_orders). The service-role
# key is server-only — never expose it to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="MY_SUPABASE_SERVICE_ROLE_KEY"

# ─── Payments: Selcom (Tanzania) ─────────────────────────────────────────────
# Feature flag for the automated Selcom flows (M-Pesa STK push + card). Leave
# unset/false until a Selcom merchant account + SELCOM_* creds exist: checkout
# then shows ONLY the manual Lipa Namba flow (customer pays, enters their
# reference, team confirms). Set to "true" to enable push + card.
NEXT_PUBLIC_PAYMENTS_SELCOM_ENABLED="false"

# Selcom Checkout API credentials. Sandbox values for dev; live values on prod.
# The webhook (set in the Selcom dashboard) must point to
#   <NEXT_PUBLIC_OPUS_PASS_URL>/api/payments/webhook
SELCOM_BASE_URL="https://apigwtest.selcommobile.com/v1"   # live: https://apigw.selcommobile.com/v1
SELCOM_API_KEY="MY_SELCOM_API_KEY"
SELCOM_API_SECRET="MY_SELCOM_API_SECRET"
SELCOM_VENDOR_ID="MY_SELCOM_VENDOR_ID"

# Public origin of the OpusPass app — used to build the Selcom redirect/webhook
# URLs. Must be the publicly reachable HTTPS URL in production.
NEXT_PUBLIC_OPUS_PASS_URL="https://opuspass.opusfesta.com"

# Public origin of the OpusFesta marketplace site (opus_website). Used by the
# dashboard chrome to link to the marketplace and the couple's vendor inquiries
# (<URL>/my/inquiries). Defaults to http://localhost:3006 for local dev.
NEXT_PUBLIC_SITE_URL="https://opusfesta.com"

# ─── Transactional email: invitation payment review ─────────────────────────
# RESEND_API_KEY must be set in production for invoice/review emails.
# INVITATION_PAYMENTS_ADMIN_EMAIL can be comma-separated for multiple finance
# recipients. FINANCE_EMAIL is the fallback used by payment emails.
RESEND_API_KEY="MY_RESEND_API_KEY"
RESEND_FROM_EMAIL="OpusFesta <admin@opusfesta.com>"
INVITATION_PAYMENTS_ADMIN_EMAIL="finance@opusfesta.com"
FINANCE_EMAIL="finance@opusfesta.com"

# ─── WhatsApp Business (Meta Cloud API) ─────────────────────────────────────
# When these are set the app sends real invitation template messages; when
# unset it falls back to a dry-run stub that logs but does not send.
#   WHATSAPP_PHONE_NUMBER_ID        from the Meta WhatsApp number
#   WHATSAPP_ACCESS_TOKEN           system-user permanent token (whatsapp_business_messaging)
#   WHATSAPP_TEMPLATE_NAME          approved template (image header + {{1}} body + 3 quick-reply buttons)
#   WHATSAPP_TEMPLATE_LANG          template language code (e.g. sw)
#   WHATSAPP_WEBHOOK_VERIFY_TOKEN   arbitrary secret echoed in the webhook GET handshake
#   WHATSAPP_APP_SECRET             Meta app secret; signs inbound webhook POSTs
#                                   (X-Hub-Signature-256). When set, unsigned or
#                                   mismatched POSTs are rejected. Leave unset in
#                                   dev to skip verification.
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_TEMPLATE_NAME=""
WHATSAPP_TEMPLATE_LANG="sw"
# Contact Collector / Pledge link-request templates (dynamic-URL button each);
# unset means that specific send kind reports "not configured".
WHATSAPP_TEMPLATE_NAME_COLLECTOR=""
WHATSAPP_TEMPLATE_LANG_COLLECTOR="sw"
WHATSAPP_TEMPLATE_NAME_PLEDGE=""
WHATSAPP_TEMPLATE_LANG_PLEDGE="sw"
WHATSAPP_TEMPLATE_NAME_ENTRANCE_PASS=""
WHATSAPP_TEMPLATE_LANG_ENTRANCE_PASS="sw"
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""

# ─── Guest entrance-pass QR (check-in) ──────────────────────────────────────
# Signs/verifies the HMAC token embedded in each attending guest's QR code.
# Required for the entrance-pass image route and any future door-scanner app
# to work — without it, ticket generation throws.
CHECKIN_TOKEN_SECRET=""
