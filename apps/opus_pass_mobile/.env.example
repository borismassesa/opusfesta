# Clerk Authentication — same instance as the opus_pass web app
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Supabase (same project as the rest of the monorepo)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Public origin of the OpusPass web app — used to open host-only surfaces
# (website builder, payment checkout) that stay on web for now.
EXPO_PUBLIC_OPUS_PASS_URL=https://opuspass.opusfesta.com

# Public origin of the OpusFesta marketing/web app. The vendor inquiry and
# proposal accept/counter flows call its /api/my/inquiries routes rather than
# Supabase directly — couples have no UPDATE policy on `inquiries`, and that
# app already owns the proposal state machine. Requires the same Clerk instance.
EXPO_PUBLIC_OPUS_WEBSITE_URL=https://www.opusfesta.com
