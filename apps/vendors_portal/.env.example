# OpusFesta Supabase project (shared with opus_website + opus_admin)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only — keep out of NEXT_PUBLIC_*. Used for trusted writes that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Clerk (shared with opus_website + opus_admin)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Where vendors land after sign-in / sign-up. Set to /dashboard so existing
# vendors go straight to their portal dashboard, and /onboard so new vendors
# enter the onboarding wizard. The <SignIn> / <SignUp> components also pass
# fallbackRedirectUrl props as a safety net, but env vars take precedence
# when set.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboard

# Vendors portal URL — used for self-referential links
NEXT_PUBLIC_APP_URL=http://localhost:3003

# Shared secret with opus_admin for ISR cache invalidation. When admins
# publish changes from /cms/vendors-portal/* the admin app POSTs to
# /api/revalidate on this app — this secret must match opus_admin's
# VENDORS_PORTAL_REVALIDATE_SECRET. Without it, "Publish" appears to
# succeed but public pages keep serving stale ISR content.
VENDORS_PORTAL_REVALIDATE_SECRET=
